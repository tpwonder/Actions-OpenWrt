# ================================
# H3C Magic NX30 Pro (MT7981/Filogic) 
# Lean's LEDE OpenWrt Build Config
# ================================

# Target
CONFIG_TARGET_mediatek=y
CONFIG_TARGET_mediatek_filogic=y

# Device
CONFIG_TARGET_mediatek_filogic_DEVICE_h3c_magic-nx30-pro=y

# ================================
# Build Options
# ================================
CONFIG_PACKAGE_kmod-crypto-hw-safexcel=m
CONFIG_PACKAGE_kmod-mt7915e=m
CONFIG_PACKAGE_wpad-openssl=m
CONFIG_PACKAGE_uboot-envtools=m

# ================================
# LuCI and Web UI
# ================================
CONFIG_PACKAGE_luci=y
CONFIG_PACKAGE_luci-compat=y

# ================================
# Themes
# ================================
CONFIG_PACKAGE_luci-theme-argon=y
CONFIG_PACKAGE_luci-app-argon-config=y

# ================================
# Common Packages
# ================================
CONFIG_PACKAGE_curl=y
CONFIG_PACKAGE_wget-ssl=y
CONFIG_PACKAGE_opkg=y
CONFIG_PACKAGE_nan=y

# ================================
# Network
# ================================
CONFIG_PACKAGE_ppp=y
CONFIG_PACKAGE_ppp-mod-pppoe=y
CONFIG_PACKAGE_firewall=y
CONFIG_PACKAGE_ip6tables=y
CONFIG_PACKAGE_iptables=y

# ================================
# Filesystem
# ================================
CONFIG_PACKAGE_f2fs-tools=y
CONFIG_PACKAGE_block-mount=y

# ================================
# Helloworld (SSR Plus)
# ================================
CONFIG_PACKAGE_luci-app-ssr-plus=y
